{
    "image": "dl_normal",
    "runArgs": [
        "--name=yang_dl_normal",
        "--net=host",
        "--ipc=host",
        "--gpus=all",
        "-e", "NVIDIA_DRIVER_CAPABILITIES=all", 
        "--privileged"
    ], 
    "mounts": [
        "source=S:/Coding/DeepLearningFramework,target=/root/workspace,type=bind",
        "source=S:/Data,target=/root/share,type=bind"
    ], 
    "workspaceFolder": "/root/workspace", 
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "ms-python.black-formatter",
                "ms-azuretools.vscode-docker",
                "github.copilot",
                "github.vscode-pull-request-github",
                "ChirtleLovesDolls.nebula-theme"
            ]
        }
    }
}